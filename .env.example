# ==============================================================================
#  SISTEMA WEB DE FORMACIÓN MILITAR - UNEFA FALCÓN
#  Aplicación Web para la Formación de Estudiantes en Conocimientos Militares
# ==============================================================================
#
#  INSTRUCCIONES PARA NUEVOS DESARROLLADORES:
#  1. Copiar este archivo: cp .env.example .env
#  2. Generar la clave de aplicación: php artisan key:generate
#  3. Completar las credenciales de la base de datos (sección DB_*)
#  4. NUNCA subir el archivo .env al repositorio. Está excluido en .gitignore.
#
# ==============================================================================

APP_NAME="Sistema Militar UNEFA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Caracas

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================================================
#  BASE DE DATOS - MYSQL (Aiven Cloud)
#  Configurar con las credenciales proporcionadas en Aiven Console.
#  Formato del host: mysql-xxxxxxxx.aivencloud.com
# ==============================================================================
DB_CONNECTION=sqlite
# DB_HOST=your-mysql-host.aivencloud.com
# DB_PORT=3306
# DB_DATABASE=sistema_militar
# DB_USERNAME=avnadmin
# DB_PASSWORD=

# SSL (requerido por Aiven para conexiones remotas seguras)
# Descarga el certificado CA desde tu panel de Aiven y colócalo en storage/app/
# MYSQL_SSL_CA=

# ==============================================================================
#  SESIONES Y CACHÉ
# ==============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ==============================================================================
#  CORREO ELECTRÓNICO (Opcional para este proyecto académico)
# ==============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="sistema@unefafalcon.edu.ve"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================================================
#  VITE (Asset Bundler)
# ==============================================================================
VITE_APP_NAME="${APP_NAME}"
